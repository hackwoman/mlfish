/* app.wxss - 全局样式 - 卡通轻松风格 */

/* 主题色 */
page {
  --primary-color: #159895;
  --primary-light: #1a7a74;
  --primary-dark: #0d6b68;
  
  --secondary-color: #f5a623;
  --accent-color: #e74c3c;
  
  --bg-color: #f8f9fa;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  
  --border-color: #eeeeee;
  --shadow: 0 4rpx 20rpx rgba(21, 152, 149, 0.1);
  
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 通用容器 */
.container {
  padding: 30rpx;
}

/* 卡片 */
.card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow);
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-primary {
  background: var(--primary-color);
  color: #fff;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background: #fff;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.btn-disabled {
  background: #ccc;
  color: #999;
}

/* 标题 */
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.title-xl {
  font-size: 44rpx;
  font-weight: 700;
}

.subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-success {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-warning {
  background: #fff3e0;
  color: #f57c00;
}

.tag-danger {
  background: #ffebee;
  color: #c62828;
}

.tag-info {
  background: #e3f2fd;
  color: #1565c0;
}

/* 价格 */
.price {
  color: var(--accent-color);
  font-weight: 600;
}

.price-xl {
  font-size: 40rpx;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 20rpx 0;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

/* Flex工具 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 文字颜色 */
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-light { color: var(--text-light); }
.text-accent { color: var(--accent-color); }
.text-success { color: #2e7d32; }

/* 文字大小 */
.text-sm { font-size: 24rpx; }
.text-md { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }

/* 圆角 */
.radius-sm { border-radius: 10rpx; }
.radius-md { border-radius: 20rpx; }
.radius-lg { border-radius: 30rpx; }
.radius-full { border-radius: 50%; }
