/* bookings.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  padding: 15rpx 0;
  position: relative;
}

.tab.active {
  color: #159895;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #159895;
  border-radius: 2rpx;
}

.booking-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.booking-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 25rpx;
}

.booking-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.booking-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.booking-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.booking-status.pending {
  background: #fff3e0;
  color: #f57c00;
}

.booking-status.confirmed {
  background: #e8f5e9;
  color: #2e7d32;
}

.booking-status.completed {
  background: #e3f2fd;
  color: #1565c0;
}

.booking-status.cancelled {
  background: #f5f5f5;
  color: #999;
}

.booking-info {
  display: flex;
  gap: 30rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.booking-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.booking-footer .price {
  font-size: 32rpx;
  font-weight: 600;
  color: #e74c3c;
}

.booking-actions {
  display: flex;
  gap: 15rpx;
}

.btn-secondary {
  padding: 12rpx 30rpx;
  border: 2rpx solid #ddd;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
}

.btn-primary {
  padding: 12rpx 30rpx;
  background: #159895;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #fff;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
