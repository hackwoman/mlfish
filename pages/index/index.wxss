@import "banner-styles.wxss";
/* index.wxss - 首页样式 - 全新设计 */

.container {
  min-height: 100vh;
  background: #f0f4f8;
}

/* 轮播Banner */
.banner {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.banner-swiper {
  height: 100%;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
}

.banner-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.banner-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5);
}

.banner-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5);
}

/* 天气统计 */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background: #fff;
  margin: -30rpx 20rpx 20rpx;
  border-radius: 20rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.stat-card {
  text-align: center;
}

.stat-card .stat-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.stat-card .stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.stat-card .stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #159895, #1a7a74);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

/* 日历卡片 */
.calendar-card {
  padding: 25rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.calendar-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.calendar-btns {
  display: flex;
  gap: 20rpx;
}

.calendar-btn {
  font-size: 32rpx;
  color: #159895;
  padding: 10rpx 20rpx;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 10rpx;
}

.weekday {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 15rpx 0;
}

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.day {
  text-align: center;
  font-size: 28rpx;
  padding: 15rpx 0;
  color: #333;
  position: relative;
}

.day.today {
  background: #159895;
  color: #fff;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0 auto;
}

.day.has-activity::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: #e74c3c;
  border-radius: 50%;
}

.day.has-bookings {
  background: #e8f5e9;
  border-radius: 10rpx;
}

.day.has-trip {
  background: #bbdefb;
  border-radius: 10rpx;
}

.booking-badge {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  background: #159895;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
}

.trip-badge {
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  font-size: 18rpx;
}

.calendar-legend {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #666;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-emoji {
  font-size: 20rpx;
}

.dot-red { background: #e74c3c; }
.dot-blue { background: #159895; }
.dot-green { background: #4caf50; }

/* Section */
.section {
  margin: 0 20rpx 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

/* 预约列表 */
.booking-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.booking-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.booking-item:last-child {
  border-bottom: none;
}

.booking-date {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.booking-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.booking-cancel {
  color: #e74c3c;
  font-size: 26rpx;
}

/* 活动列表 */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  display: flex;
}

.activity-cover {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.activity-icon {
  font-size: 80rpx;
}

.activity-content {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.activity-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-tags {
  display: flex;
  gap: 10rpx;
  margin-top: 10rpx;
}

.tag-date {
  background: #e8f5e9;
  color: #2e7d32;
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
}

.tag-success {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-warning {
  background: #fff3e0;
  color: #f57c00;
}

.tag-danger {
  background: #ffebee;
  color: #c62828;
}

.tag-info {
  background: #e3f2fd;
  color: #1976d2;
}

.activity-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}

.activity-meta .price {
  font-size: 36rpx;
  font-weight: 700;
  color: #e74c3c;
}

/* 小贴士 */
.tips-card {
  background: linear-gradient(135deg, #159895, #1a7a74);
}

.tips-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 15rpx;
}

.tips-content {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.8;
}

/* 底部占位 */
.bottom-space {
  height: 40rpx;
}

/* ========== 弹窗样式 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.booking-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  z-index: 101;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.modal-close {
  font-size: 44rpx;
  color: #999;
  padding: 10rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.form-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.time-slots {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.time-slot {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.time-slot.active {
  background: #159895;
  color: #fff;
}

.people-selector {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.people-btn {
  width: 64rpx;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #159895;
}

.people-count {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  min-width: 60rpx;
  text-align: center;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.btn-submit {
  background: linear-gradient(135deg, #159895, #1a7a74);
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 30rpx;
}

/* 船长面板 */
.captain-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.panel-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.panel-close {
  font-size: 44rpx;
  color: #999;
  padding: 10rpx;
}

.panel-stats {
  display: flex;
  gap: 30rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  flex: 1;
  background: #e3f2fd;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
}

.stat-item .stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #159895;
}

.stat-item .stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.panel-bookings {
  margin-bottom: 30rpx;
}

.booking-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 15rpx;
}

.booking-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.booking-row:last-child {
  border-bottom: none;
}

.booking-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.booking-detail {
  font-size: 24rpx;
  color: #666;
  margin-top: 6rpx;
}

.panel-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-start-trip {
  background: linear-gradient(135deg, #159895, #1a7a74);
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-end-trip {
  background: #e74c3c;
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.trip-info-box {
  background: #e8f5e9;
  color: #2e7d32;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
}
