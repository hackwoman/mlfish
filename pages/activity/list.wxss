/* activity.wxss */
.activity-list {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.filter-bar {
  display: flex;
  padding: 20rpx 30rpx;
  background: #fff;
  gap: 20rpx;
}

.filter-item {
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}

.filter-item.active {
  background: #159895;
  color: #fff;
}

.list-scroll {
  flex: 1;
  padding: 20rpx;
}

.activity-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  display: flex;
  margin-bottom: 20rpx;
}

.activity-cover {
  width: 200rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.activity-icon {
  font-size: 60rpx;
}

.activity-content {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.activity-tags {
  display: flex;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.tag {
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
}

.tag-date {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-success {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-warning {
  background: #fff3e0;
  color: #f57c00;
}

.tag-danger {
  background: #ffebee;
  color: #c62828;
}

.activity-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.activity-meta .price {
  font-size: 32rpx;
  font-weight: 600;
  color: #e74c3c;
}
